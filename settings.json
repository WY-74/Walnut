{
    "mcpServers": {
        "lixinger": {
            "command": "D:/projects/Walnut/walnut/Scripts/python.exe",
            "args": [".agents/mcp_tools/lixinger.py"],
            "env": {
                "LIXINGER_TOKEN": "${LIXINGER_TOKEN}"
